# Server environment example
# Copy to .env and fill with real secrets.

NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://postgres:secret123@localhost:5432/ph_health?schema=public

BETTER_AUTH_SECRET=change-me
BETTER_AUTH_URL=http://localhost:5000

ACCESS_TOKEN_SECRET=change-me
REFRESH_TOKEN_SECRET=change-me
ACCESS_TOKEN_EXPIRES_IN=1d
REFRESH_TOKEN_EXPIRES_IN=7d
BETTER_AUTH_SESSION_TOKEN_EXPIRES_IN=1d
BETTER_AUTH_SESSION_TOKEN_UPDATE_AGE=1d

EMAIL_SENDER_SMTP_USER=you@example.com
EMAIL_SENDER_SMTP_PASS=change-me
EMAIL_SENDER_SMTP_HOST=smtp.example.com
EMAIL_SENDER_SMTP_PORT=587
EMAIL_SENDER_SMTP_FROM=PH Healthcare <noreply@example.com>

GOOGLE_CLIENT_ID=change-me
GOOGLE_CLIENT_SECRET=change-me
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/callback/google

FRONTEND_URL=http://localhost:3000

CLOUDINARY_CLOUD_NAME=change-me
CLOUDINARY_API_KEY=change-me
CLOUDINARY_API_SECRET=change-me

STRIPE_SECRET_KEY=change-me
STRIPE_WEBHOOK_SECRET=change-me

SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=change-me
